{
  "version": 2,
  "framework": "vite",
  "outputDirectory": "dist/public",
  "routes": [
    { "src": "/api/minimal", "dest": "/api/minimal" },
    { "src": "/api/static-test", "dest": "/api/static-test" },
    { "src": "/api/(.*)", "dest": "/api/index" },
    { "src": "/scrape-data.json", "dest": "/scrape-data.json" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
