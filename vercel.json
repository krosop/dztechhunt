{
  "version": 2,
  "framework": "vite",
  "outputDirectory": "dist/public",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/scrape-data.json", "destination": "/scrape-data.json" },
    { "source": "/assets/:path*", "destination": "/assets/:path*" },
    { "source": "/:path*", "destination": "/index.html" }
  ]
}
